# Public site URL. For Vercel preview/test deploy, use the vercel.app URL.
NEXT_PUBLIC_APP_URL="https://qr-attendance-system.vercel.app"

# Project lesson timezone. Current client uses MSK+4.
PROJECT_TIME_ZONE="Asia/Krasnoyarsk"

# Long random value for signed auth cookies. Generate a unique value for production.
SESSION_SECRET="replace-with-a-long-random-secret"

# PostgreSQL, for Supabase or Neon
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# First owner seed. Set these in Vercel env and in the shell before running npm run db:seed.
SEED_OWNER_LOGIN="owner"
SEED_OWNER_PASSWORD="replace-with-initial-owner-password"

# Local demo only. Do not set this on Vercel production.
# DEMO_DATABASE="1"
